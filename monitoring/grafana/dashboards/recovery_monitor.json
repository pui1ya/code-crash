{
  "annotations": {
    "list": []
  },

  "editable": true,

  "graphTooltip": 0,

  "links": [],

  "panels": [

    {
      "id": 1,

      "title": "Worker Crashes",

      "type": "stat",

      "datasource": "Prometheus",

      "targets": [
        {
          "expr": "crashreduce_worker_crashes_total"
        }
      ],

      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      }
    },

    {
      "id": 2,

      "title": "Task Reassignments",

      "type": "stat",

      "datasource": "Prometheus",

      "targets": [
        {
          "expr": "crashreduce_task_reassignments_total"
        }
      ],

      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 0
      }
    },

    {
      "id": 3,

      "title": "Recovered Tasks",

      "type": "stat",

      "datasource": "Prometheus",

      "targets": [
        {
          "expr": "crashreduce_recovered_tasks_total"
        }
      ],

      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 0
      }
    },

    {
      "id": 4,

      "title": "Average Recovery Time",

      "type": "stat",

      "datasource": "Prometheus",

      "targets": [
        {
          "expr": "avg(crashreduce_recovery_time_seconds)"
        }
      ],

      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 0
      }
    },

    {
      "id": 5,

      "title": "Worker Crash Timeline",

      "type": "timeseries",

      "datasource": "Prometheus",

      "targets": [
        {
          "expr": "increase(crashreduce_worker_crashes_total[5m])"
        }
      ],

      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 4
      }
    },

    {
      "id": 6,

      "title": "Task Reassignment Rate",

      "type": "timeseries",

      "datasource": "Prometheus",

      "targets": [
        {
          "expr": "rate(crashreduce_task_reassignments_total[1m])"
        }
      ],

      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 12
      }
    },

    {
      "id": 7,

      "title": "Recovered Tasks Rate",

      "type": "timeseries",

      "datasource": "Prometheus",

      "targets": [
        {
          "expr": "rate(crashreduce_recovered_tasks_total[1m])"
        }
      ],

      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 12
      }
    },

    {
      "id": 8,

      "title": "Recovery Events",

      "type": "timeseries",

      "datasource": "Prometheus",

      "targets": [
        {
          "expr": "increase(crashreduce_recovery_events_total[5m])"
        }
      ],

      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 20
      }
    },

    {
      "id": 9,

      "title": "Recovery Success Rate",

      "type": "gauge",

      "datasource": "Prometheus",

      "targets": [
        {
          "expr": "(crashreduce_recovered_tasks_total / crashreduce_task_reassignments_total) * 100"
        }
      ],

      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 28
      }
    },

    {
      "id": 10,

      "title": "Heartbeat Timeouts",

      "type": "timeseries",

      "datasource": "Prometheus",

      "targets": [
        {
          "expr": "increase(crashreduce_heartbeat_timeouts_total[5m])"
        }
      ],

      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 28
      }
    },

    {
      "id": 11,

      "title": "Recovery Event Table",

      "type": "table",

      "datasource": "Prometheus",

      "targets": [
        {
          "expr": "crashreduce_recovery_events"
        }
      ],

      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 36
      }
    }

  ],

  "refresh": "5s",

  "schemaVersion": 38,

  "style": "dark",

  "tags": [
    "crashreduce",
    "recovery",
    "fault-tolerance"
  ],

  "templating": {

    "list": [

      {
        "name": "worker",

        "type": "query",

        "datasource": "Prometheus",

        "query":
          "label_values(crashreduce_worker_status, worker_id)",

        "multi": true,

        "includeAll": true
      }
    ]
  },

  "time": {

    "from": "now-1h",

    "to": "now"
  },

  "timezone": "",

  "title": "CrashReduce Recovery Monitor",

  "uid": "crashreduce-recovery",

  "version": 1
}